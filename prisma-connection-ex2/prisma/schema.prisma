generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model student {
  id              Int       @id @default(autoincrement())
  name            String?   @db.VarChar(100)
  email           String?   @db.VarChar(100)
  course          String?   @db.VarChar(100)
  enrollment_date DateTime? @db.Date
}